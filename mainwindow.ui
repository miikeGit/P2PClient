  <property name="styleSheet">
   <string notr="true">* {
    font-family: "Segoe UI", "Inter", "Helvetica Neue", sans-serif;
    font-size: 13px;
    color: #e6e8ef;
}

QMainWindow, QWidget#centralwidget {
    background-color: #121319;
}

QLabel#statusPill {
    padding: 5px 14px;
    border-radius: 11px;
    font-size: 12px;
    font-weight: 600;
}

QLabel#statusPill[online="true"] {
    background-color: rgba(62, 207, 142, 0.14);
    color: #3ecf8e;
    border: 1px solid rgba(62, 207, 142, 0.40);
}

QLabel#statusPill[online="false"] {
    background-color: rgba(255, 92, 92, 0.12);
    color: #ff6b6b;
    border: 1px solid rgba(255, 92, 92, 0.35);
}

QFrame#cardConnection, QFrame#cardTransfer {
    background-color: #1a1c24;
    border: 1px solid #262935;
    border-radius: 14px;
}

QLabel#sectionConnection, QLabel#sectionTransfer, QLabel#sectionDownload {
    font-size: 11px;
    font-weight: 700;
    color: #6f7488;
}

QLabel#label_1 {
    color: #8b8f9e;
}

QLabel#myIdLabel {
    font-family: "Consolas", "Menlo", monospace;
    font-weight: 700;
    color: #5b8cff;
}

QLabel#fileNameLabel {
    color: #b9bdca;
}

QLabel#statusLabel {
    color: #8b8f9e;
    font-size: 12px;
}

QLineEdit {
    background-color: #11131a;
    border: 1px solid #2a2d39;
    border-radius: 9px;
    padding: 9px 12px;
    selection-background-color: #5b8cff;
}

QLineEdit:focus {
    border: 1px solid #5b8cff;
}

QLineEdit:read-only {
    color: #8b8f9e;
}

QPushButton {
    background-color: #242736;
    border: 1px solid #2f3343;
    border-radius: 9px;
    padding: 8px 16px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #2c3042;
}

QPushButton:pressed {
    background-color: #20232f;
}

QPushButton:disabled {
    background-color: #1a1c24;
    color: #565a68;
    border: 1px solid #23262f;
}

QPushButton#callButton, QPushButton#sendFileButton {
    background-color: #5b8cff;
    border: none;
    color: #ffffff;
}

QPushButton#callButton:hover, QPushButton#sendFileButton:hover {
    background-color: #6f9bff;
}

QPushButton#callButton:pressed, QPushButton#sendFileButton:pressed {
    background-color: #4f7de0;
}

QPushButton#callButton:disabled, QPushButton#sendFileButton:disabled {
    background-color: #2a3350;
    color: #7f8aa6;
}

QPushButton#cancelButton {
    background-color: transparent;
    border: 1px solid #4a3940;
    color: #ff6b6b;
}

QPushButton#cancelButton:hover {
    background-color: rgba(255, 92, 92, 0.12);
}

QPushButton#cancelButton:disabled {
    background-color: transparent;
    border: 1px solid #2a2730;
    color: #565a68;
}

QProgressBar {
    background-color: #11131a;
    border: none;
    border-radius: 5px;
}

QProgressBar::chunk {
    background-color: #5b8cff;
    border-radius: 5px;
}

Line, QFrame[frameShape="4"] {
    color: #262935;
    background-color: #262935;
}

QStatusBar {
    background-color: #121319;
    color: #8b8f9e;
    border: none;
}

QStatusBar::item {
    border: none;
}

QToolTip {
    background-color: #1a1c24;
    color: #e6e8ef;
    border: 1px solid #2a2d39;
    border-radius: 6px;
    padding: 4px 8px;
}
</string>
